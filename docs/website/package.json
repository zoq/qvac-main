{
  "name": "qvac-docs",
  "version": "0.1.0",
  "description": "Official documentation and single source of truth for QVAC",
  "private": true,
  "scripts": {
    "prebuild:examples": "npx tsc --noCheck --noResolve --skipLibCheck --module ESNext --target ESNext --rootDir ../../packages/sdk/examples --outDir ../../packages/sdk/dist/examples ../../packages/sdk/examples/*.ts ../../packages/sdk/examples/**/*.ts",
    "build": "npm run prebuild:examples && next build && npx @vahor/next-broken-links",
    "build:static": "npm run prebuild:examples && next build && npx @vahor/next-broken-links",
    "dev": "npm run prebuild:examples && next dev --turbo -p 3001",
    "start": "next start",
    "serve": "npx http-server out -p 8080 -c-1",
    "postinstall": "fumadocs-mdx",
    "docs:generate": "bun run scripts/run-docs-generate.ts",
    "docs:generate-api": "bun run scripts/generate-api-docs.ts",
    "docs:gen-api-dev": "bun run scripts/generate-api-docs.ts --dev",
    "docs:update-versions": "bun run scripts/update-versions-list.ts",
    "docs:create-version": "bun run scripts/create-version-bundle.ts",
    "docs:release-version": "bun run scripts/release-version.ts",
    "docs:generate-release-notes": "bun run scripts/generate-release-notes.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:examples": "bun run scripts/test-code-examples.ts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^1.0.29",
    "@ai-sdk/react": "^2.0.118",
    "@icons-pack/react-simple-icons": "^13.8.0",
    "@inkeep/cxkit-react": "^0.5.111",
    "@next/third-parties": "^16.2.0",
    "@orama/orama": "^3.1.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-presence": "^1.1.5",
    "ai": "^5.0.116",
    "class-variance-authority": "^0.7.1",
    "dotenv": "^17.2.3",
    "fumadocs-core": "^16.3.2",
    "fumadocs-mdx": "^14.2.2",
    "fumadocs-ui": "^16.3.2",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "katex": "^0.16.27",
    "lucide-react": "^0.562.0",
    "mermaid": "^11.12.0",
    "next": "^16.1.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-rehype": "^11.1.2",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "@types/mdx": "^2.0.13",
    "@types/node": "24.3.3",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vahor/next-broken-links": "^0.4.1",
    "glob": "^11.0.3",
    "postcss": "^8.5.6",
    "remark": "^15.0.1",
    "remark-code-import": "^1.2.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "remark-validate-links": "^13.1.0",
    "serve": "^14.2.5",
    "tailwindcss": "^4.1.13",
    "typedoc": "^0.28.17",
    "typedoc-plugin-frontmatter": "^1.3.1",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.2",
    "unified": "^11.0.2",
    "unist-util-visit": "^5.0.0",
    "vitest": "^4.0.18",
    "nunjucks": "^3.2.4",
    "@types/nunjucks": "^3.2.6"
  }
}
