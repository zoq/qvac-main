{
  "name": "test-logger",
  "version": "0.1.0",
  "addon": true,
  "scripts": {
    "build": "bare-make generate && bare-make build && bare-make install",
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "npm run test:unit && npm run test:integration",
    "test:dts": "tsc index.d.ts --noEmit",
    "test:unit:generate": "brittle -r test/unit/all.js test/unit/*.test.js",
    "test:unit": "npm run test:unit:generate && bare test/unit/all.js",
    "test:integration:generate": "brittle -r test/integration/all.js test/integration/*.test.js",
    "test:integration": "npm run test:integration:generate && bare test/integration/all.js"
  },
  "files": [
    "binding.js",
    "index.js",
    "silerovad.js",
    "prebuilds",
    "index.d.ts",
    "utils",
    "prebuilds",
    "model",
    "lib"
  ],
  "exports": {
    "./package": "./package.json",
    ".": "./index.js"
  },
  "repository": {
    "type": "git"
  },
  "author": "Tether",
  "keywords": [
    "tether",
    "addon",
    "silero",
    "qvac"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "@qvac/dl-base": "0.2.1",
    "bare-fs": "^3.0.2",
    "bare-path": "^3.0.0",
    "bare-stream": "^2.3.0",
    "brittle": "^3.16.3",
    "cmake-bare": "^1.5.2",
    "cmake-vcpkg": "^1.0.2",
    "standard": "^17.0.0"
  },
  "bugs": "https://github.com/tetherto/qvac-lib-inference-addon-cpp/issues"
}
