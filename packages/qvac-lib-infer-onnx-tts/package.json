{
  "name": "@qvac/tts-onnx",
  "version": "0.8.4",
  "description": "Text to Speech (TTS) addon for qvac",
  "addon": true,
  "engines": {
    "bare": ">=1.19.0"
  },
  "scripts": {
    "build": "bare-make generate && bare-make build && bare-make install",
    "build:pack": "mkdir -p dist && npm pack --pack-destination dist",
    "example": "bare examples/chatterbox-tts.js english",
    "lint": "standard \"test/**/*.js\" \"*.js\" \"lib/*.js\"",
    "lint:fix": "standard --fix \"test/**/*.js\" \"*.js\" \"lib/*.js\"",
    "test:unit": "brittle-bare test/unit/**/*.test.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:integration": "brittle-bare test/integration/addon.test.js",
    "test:integration:medium": "INPUT_SENTENCES=medium brittle-bare test/integration/addon.test.js",
    "test:integration:long": "INPUT_SENTENCES=long brittle-bare test/integration/addon.test.js",
    "test:mobile:generate": "node scripts/generate-mobile-integration-tests.js",
    "test:mobile:validate": "node scripts/validate-mobile-tests.js",
    "test:cpp:build": "bare-make generate -D BUILD_TESTING=ON && bare-make build",
    "test:cpp:run": "./build/addon/test/unit/qvac-lib-inference-tts-unit-test",
    "test:cpp": "npm run test:cpp:build && npm run test:cpp:run",
    "models:ensure": "bare scripts/ensure-models.js",
    "models:ensure:chatterbox": "bare scripts/ensure-chatterbox.js",
    "models:ensure:supertonic": "bare scripts/ensure-supertonic.js",
    "coverage:cpp:build": "bare-make generate -D BUILD_TESTING=ON -D ENABLE_COVERAGE=ON && bare-make build",
    "coverage:cpp:run": "cd build/addon/test/unit && LLVM_PROFILE_FILE=default.profraw ./qvac-lib-inference-tts-unit-test --gtest_output=xml:cpp-test-results.xml",
    "coverage:cpp:summary": "cd build/addon/test/unit && llvm-cov-19 report ./qvac-lib-inference-tts-unit-test  --instr-profile=coverage.profdata -ignore-filename-regex='(test/unit|tests|build|node_modules|gtest|gmock|\\.vcpkg|/usr)/' > coverage-summary.txt",
    "coverage:cpp:report": "cd build/addon/test/unit && llvm-profdata-19 merge -sparse default.profraw -o coverage.profdata && llvm-cov-19 show ./qvac-lib-inference-tts-unit-test -instr-profile=coverage.profdata -format=html -output-dir=coverage-html -ignore-filename-regex='(test/unit|tests|build|node_modules|gtest|gmock|\\.vcpkg|/usr)/' && llvm-cov-19 export ./qvac-lib-inference-tts-unit-test -instr-profile=coverage.profdata -format=lcov -ignore-filename-regex='(test/unit|tests|build|node_modules|gtest|gmock|\\.vcpkg|/usr)/' > lcov.info && npm run coverage:cpp:summary",
    "coverage:cpp": "npm run coverage:cpp:build && npm run coverage:cpp:run && npm run coverage:cpp:report"
  },
  "files": [
    "addonLogging.js",
    "addonLogging.d.ts",
    "binding.js",
    "index.js",
    "lib",
    "prebuilds",
    "index.d.ts",
    "tts.js",
    "test/mobile",
    "test/integration",
    "test/reference-audio",
    "test/utils/runTTS.js",
    "test/utils/runChatterboxTTS.js",
    "test/utils/runSupertonicTTS.js",
    "test/utils/downloadModel.js",
    "test/utils/wav-helper.js",
    "test/utils/lavasr-helpers.js",
    "test/utils/loader.fake.js",
    "test/utils/runWhisper.js",
    "LICENSE",
    "NOTICE"
  ],
  "exports": {
    "./package": "./package.json",
    ".": "./index.js",
    "./text-chunker": "./lib/textChunker.js",
    "./addonLogging": {
      "types": "./addonLogging.d.ts",
      "default": "./addonLogging.js"
    },
    "./addonLogging.js": "./addonLogging.js",
    "./lib/textStreamAccumulator.js": "./lib/textStreamAccumulator.js"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetherto/qvac.git",
    "directory": "packages/qvac-lib-infer-onnx-tts"
  },
  "bugs": "https://github.com/tetherto/qvac/issues",
  "homepage": "https://github.com/tetherto/qvac/tree/main/packages/qvac-lib-infer-onnx-tts#readme",
  "devDependencies": {
    "@qvac/transcription-whispercpp": "^0.5.5",
    "bare-buffer": "^3.4.2",
    "bare-node-stream": "^1.0.0",
    "bare-process": "^4.2.2",
    "bare-subprocess": "^5.2.1",
    "bare-tty": "^5.0.3",
    "brittle": "^3.17.0",
    "cmake-bare": "^1.7.5",
    "cmake-vcpkg": "^1.1.0",
    "fflate": "^0.8.2",
    "fs": "npm:bare-fs",
    "husky": "^9.1.7",
    "os": "npm:bare-os@^3.6.2",
    "process": "npm:bare-process",
    "sinon": "^21.0.0",
    "standard": "^17.0.0",
    "stream": "npm:bare-node-stream",
    "tty": "npm:bare-node-tty",
    "util": "npm:bare-utils@^1.5.1"
  },
  "dependencies": {
    "@qvac/error": "^0.1.0",
    "@qvac/onnx": "^0.14.0",
    "@qvac/infer-base": "^0.4.0",
    "bare-fs": "^4.5.6",
    "bare-os": "^3.8.0",
    "bare-path": "^3.0.0"
  },
  "types": "index.d.ts"
}
