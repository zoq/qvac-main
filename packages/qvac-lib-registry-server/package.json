{
  "name": "@qvac/registry-server",
  "version": "0.1.0",
  "description": "QVAC Registry server: exposes replication endpoints and lifecycle scripts for bare/pear",
  "license": "Apache-2.0",
  "type": "commonjs",
  "main": "index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tetherto/qvac.git",
    "directory": "packages/qvac-lib-registry-server"
  },
  "bugs": {
    "url": "https://github.com/tetherto/qvac/issues"
  },
  "homepage": "https://github.com/tetherto/qvac/tree/main/packages/qvac-lib-registry-server#readme",
  "keywords": [
    "qvac",
    "registry",
    "hypercore",
    "hyperdb",
    "p2p",
    "model-registry",
    "hyperswarm",
    "hyperblobs"
  ],
  "files": [
    "index.js",
    "lib/",
    "scripts/",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build:spec": "node scripts/build-db-spec.js",
    "add-model": "node scripts/add-model.js",
    "add-all-models": "node scripts/add-all-models.js",
    "run-blind-peer": "node scripts/run-blind-peer.js",
    "cleanup": "node scripts/cleanup.js",
    "validate:models": "node scripts/validate-models-json.js",
    "verify:licenses": "node scripts/verify-model-licenses.js",
    "sync:models": "node scripts/sync-models.js",
    "smoke-test": "node scripts/smoke-test-client.js",
    "test:unit": "brittle-node tests/unit/*.test.js",
    "test:integration": "brittle-node tests/integration/*.test.js",
    "test:gguf": "node scripts/test-gguf-extraction.js",
    "test": "npm run test:unit && npm run test:integration",
    "lint": "standard",
    "lint:fix": "standard --fix"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.998.0",
    "@huggingface/gguf": "^0.3.3",
    "@huggingface/hub": "^2.4.1",
    "@qvac/registry-schema": "^0.1.1",
    "autobase": "^7.18.1",
    "b4a": "^1.6.7",
    "blind-peer": "^2.9.4",
    "blind-peering": "^1.15.0",
    "buffer": "npm:bare-node-buffer",
    "compact-encoding": "^2.15.0",
    "corestore": "^7.4.5",
    "crypto": "npm:bare-node-crypto",
    "http": "npm:bare-node-http",
    "https": "npm:bare-node-https",
    "hyperblobs": "^2.8.0",
    "hypercore-id-encoding": "^1.3.0",
    "hyperdb": "^4.16.0",
    "hyperdispatch": "^1.4.0",
    "hyperschema": "^1.13.0",
    "hyperswarm": "^4.10.5",
    "paparam": "^1.8.6",
    "pino": "^9.9.4",
    "pino-pretty": "^13.1.1",
    "protomux-rpc": "^1.7.0",
    "readline": "npm:bare-node-readline",
    "ready-resource": "^1.2.0",
    "stream": "npm:bare-node-stream"
  },
  "overrides": {
    "minimatch": ">=3.1.3",
    "ajv": "6.14.0"
  },
  "devDependencies": {
    "@qvac/error": "^0.1.0",
    "brittle": "^3.4.0",
    "dotenv": "^17.2.3",
    "standard": "^17.1.0",
    "zod": "^3.24.0"
  }
}
