{
  "name": "@qvac/registry-client",
  "version": "0.2.0",
  "description": "QVAC Registry client library for read-only queries via Hyperswarm",
  "license": "Apache-2.0",
  "type": "commonjs",
  "main": "index.js",
  "bin": {
    "qvac-registry": "./bin/cli.js"
  },
  "exports": {
    ".": "./index.js",
    "./types": "./index.d.ts"
  },
  "imports": {
    "#os": {
      "bare": "bare-os",
      "default": "./lib/compat/os.js"
    },
    "#path": {
      "bare": "bare-path",
      "default": "./lib/compat/path.js"
    },
    "#fs": {
      "bare": "bare-fs",
      "default": "./lib/compat/fs.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "bin/",
    "lib/",
    "utils/",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "test:unit": "brittle tests/unit/*.test.js",
    "test:unit:bare": "brittle-bare tests/unit/*.test.js",
    "test": "npm run test:unit && npm run test:integration",
    "lint": "standard",
    "lint:fix": "standard --fix",
    "typecheck": "npx tsc --noEmit"
  },
  "dependencies": {
    "@qvac/error": "^0.1.0",
    "@qvac/registry-schema": "^0.1.1",
    "b4a": "^1.6.7",
    "bare-fs": "^4.5.2",
    "bare-os": "^3.6.2",
    "bare-path": "^3.0.0",
    "bare-process": "^4.2.2",
    "corestore": "^7.4.5",
    "hyperblobs": "^2.8.0",
    "hypercore-id-encoding": "^1.3.0",
    "hyperdb": "^4.16.1",
    "hyperswarm": "^4.14.0",
    "paparam": "^1.10.0",
    "ready-resource": "^1.0.1"
  },
  "devDependencies": {
    "brittle": "^3.4.0",
    "dotenv": "^17.2.3",
    "standard": "^17.1.0",
    "test-tmp": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
