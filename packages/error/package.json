{
  "name": "@qvac/error",
  "version": "0.1.2",
  "description": "Base error handling library for QVAC",
  "main": "index.js",
  "scripts": {
    "lint": "standard",
    "lint:fix": "standard --fix",
    "build:types": "tsc",
    "test:unit": "npm run test:unit:generate && bare test/unit/all.js",
    "test:dts": "tsc index.d.ts --noEmit",
    "test:unit:generate": "brittle -r test/unit/all.js test/unit/*.test.js",
    "test": "npm run test:unit && npm run test:dts",
    "test:coverage": "brittle --coverage test/**/*.test.js",
    "prepare": "husky || true"
  },
  "author": "Tether",
  "keywords": [
    "tether",
    "error",
    "qvac"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "brittle": "^3.10.1",
    "husky": "^9.1.7",
    "standard": "17.1.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetherto/qvac.git",
    "directory": "packages/error"
  },
  "bugs": "https://github.com/tetherto/qvac/issues",
  "homepage": "https://github.com/tetherto/qvac/tree/main/packages/error#readme",
  "files": [
    "src",
    "index.d.ts",
    "LICENSE",
    "NOTICE"
  ],
  "types": "index.d.ts"
}
